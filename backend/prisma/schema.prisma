generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Produk {
  id            Int     @id @default(autoincrement())
  kategoriId    Int
  subKategoriId Int?
  brandId       Int
  nama          String
  harga         Decimal @db.Decimal(10, 2)
  deskripsi     String? @db.Text
  estBerat      Decimal @db.Decimal(10, 2)
  stok          Int
  isDeleted     Boolean @default(false)

  Kategori        Kategori          @relation(fields: [kategoriId], references: [id])
  SubKategori     SubKategori?      @relation(fields: [subKategoriId], references: [id])
  Brand           Brand             @relation(fields: [brandId], references: [id])
  Keranjang       Keranjang[]
  Favorit         Favorit[]
  Media           Media[]
  SimulasiDetail  SimulasiDetail[]
  TransaksiDetail TransaksiDetail[]
  ProdukTipeRam   ProdukTipeRam[]
  ProdukSocket    ProdukSocket[]

  @@index([kategoriId])
  @@index([subKategoriId])
  @@index([brandId])
}

model Kategori {
  id     Int      @id @default(autoincrement())
  nama   String   @unique
  Produk Produk[]
}

model SubKategori {
  id     Int      @id @default(autoincrement())
  nama   String   @unique
  Produk Produk[]
}

model Brand {
  id     Int      @id @default(autoincrement())
  nama   String   @unique
  Produk Produk[]
}

model Socket {
  id           Int            @id @default(autoincrement())
  nama         String         @unique
  ProdukSocket ProdukSocket[]
}

model ProdukSocket {
  id       Int    @id @default(autoincrement())
  produkId Int
  socketId Int
  Produk   Produk @relation(fields: [produkId], references: [id])
  Socket   Socket @relation(fields: [socketId], references: [id])
}

model TipeRam {
  id            Int             @id @default(autoincrement())
  nama          String          @unique
  ProdukTipeRam ProdukTipeRam[]
}

model ProdukTipeRam {
  id        Int     @id @default(autoincrement())
  produkId  Int
  tipeRamId Int
  Produk    Produk  @relation(fields: [produkId], references: [id])
  TipeRam   TipeRam @relation(fields: [tipeRamId], references: [id])
}

model Simulasi {
  id             Int              @id @default(autoincrement())
  userId         String
  judul          String
  deskripsi      String
  tanggal        DateTime
  User           User             @relation(fields: [userId], references: [id])
  SimulasiDetail SimulasiDetail[]

  @@index([userId])
}

model SimulasiDetail {
  id         Int      @id @default(autoincrement())
  simulasiId Int
  produkId   Int
  Simulasi   Simulasi @relation(fields: [simulasiId], references: [id])
  Produk     Produk   @relation(fields: [produkId], references: [id])

  @@index([simulasiId, produkId])
}

model User {
  id           String         @id @default(uuid())
  roleId       Int
  username     String
  email        String         @unique
  password     String
  alamat       String
  noHp         String
  Simulasi     Simulasi[]
  Transaksi    Transaksi[]
  Keranjang    Keranjang[]
  Favorit      Favorit[]
  LogTransaksi LogTransaksi[]

  Role Role @relation(fields: [roleId], references: [id])

  @@unique([email])
}

model Keranjang {
  id         Int      @id @default(autoincrement())
  produkId   Int
  userId     String
  jumlah     Int      @default(1)
  tanggal    DateTime
  Produk     Produk   @relation(fields: [produkId], references: [id])
  User       User     @relation(fields: [userId], references: [id])
  isSelected Boolean  @default(true)

  @@index([produkId])
  @@index([userId])
}

model Transaksi {
  id              Int               @id @default(autoincrement())
  userId          String
  totalBarang     Int
  hargaTotal      Decimal           @db.Decimal(10, 2)
  deskripsi       String
  User            User              @relation(fields: [userId], references: [id])
  TransaksiDetail TransaksiDetail[]
  LogTransaksi    LogTransaksi[]

  @@index([userId])
}

model TransaksiDetail {
  id          Int       @id @default(autoincrement())
  produkId    Int
  transaksiId Int
  jumlah      Int
  hargaTotal  Decimal   @db.Decimal(10, 2)
  Produk      Produk    @relation(fields: [produkId], references: [id])
  Transaksi   Transaksi @relation(fields: [transaksiId], references: [id])

  @@index([produkId, transaksiId])
}

model Favorit {
  id       Int    @id @default(autoincrement())
  produkId Int
  userId   String
  Produk   Produk @relation(fields: [produkId], references: [id])
  User     User   @relation(fields: [userId], references: [id])
}

model Media {
  id       Int    @id @default(autoincrement())
  produkId Int
  sumber   String
  tipeFile String
  Produk   Produk @relation(fields: [produkId], references: [id])
}

model Role {
  id        Int    @id @default(autoincrement())
  nama      String
  deskripsi String
  User      User[]
}

model LogTransaksi {
  id          Int      @id @default(autoincrement())
  transaksiId Int
  userId      String
  status      Int
  waktu       DateTime

  Transaksi Transaksi @relation(fields: [transaksiId], references: [id])
  User      User      @relation(fields: [userId], references: [id])
}
